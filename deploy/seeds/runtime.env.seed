POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=hearthlight

RABBITMQ_HOST=rabbitmq
RABBITMQ_EXCHANGE=test

WEBAPP_API_HOST_PORT=8000
WEBAPP_UI_HOST_PORT=3000
POSTGRES_HOST_PORT=5433
RABBITMQ_HOST_PORT=5673
RABBITMQ_MANAGEMENT_HOST_PORT=15672
WEBAPP_ALLOW_REMOTE_WITHOUT_API_KEY=false
WEBAPP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
WEBAPP_MAX_REQUEST_BYTES=5242880

# Set a shared API key before exposing the control-plane API beyond localhost.
# WEBAPP_API_KEY=replace-with-random-secret

RESOURCE_CPU_THRESHOLD_PERCENT=95
RESOURCE_MEMORY_THRESHOLD_PERCENT=95
RESOURCE_DISK_THRESHOLD_PERCENT=95
RESOURCE_GPU_THRESHOLD_PERCENT=95
RESOURCE_GPU_MEMORY_THRESHOLD_PERCENT=95

RESOURCE_CPU_DRIFT_THRESHOLD_PERCENT=20
RESOURCE_MEMORY_DRIFT_THRESHOLD_PERCENT=10
RESOURCE_DISK_DRIFT_THRESHOLD_PERCENT=5
RESOURCE_GPU_DRIFT_THRESHOLD_PERCENT=25
